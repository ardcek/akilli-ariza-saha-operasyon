// ─── ANA PROGRAM ─────────────────────────────────────────

{
  InitAllArrays;
  LoadDemoData;

  AktifKullaniciId = 0;
  AktifKullaniciAd = '';
  AktifRol = '';

  RouterForm = TclStyleForm.Create(Self);
  RouterForm.clSetStyle(RouterForm.LightSB);

  UnitGiris = TclUnit.Create;
  UnitGiris.UnitName = 'giris_module';
  UnitGiris.CallerForm = RouterForm;
  UnitGiris.Run;

  RouterForm.Run;
}
