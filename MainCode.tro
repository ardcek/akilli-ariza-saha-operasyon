function CanBeAssigned(PerIdx: Integer): Boolean;
{
  Result = True;
  if (ArrPerAktifIs.GetItem(PerIdx) >= 5) Result = False;
}

void OnPersonelSec;
{
  SeciliPersonelIdx = TClProButton(AtamaForm.clSender).clTagInt;
  lblAtamaSonuc.Text = 'Secilen: ' + ArrPerAd.GetItem(SeciliPersonelIdx);
}

void OnAta;
var
  PerId : Integer;
  PerAd : String;
  TNo   : String;
  j     : Integer;
{
  if (SeciliPersonelIdx < 0)
  {
    lblAtamaSonuc.Text = 'Hata: Oncelikle bir personel secin.';
    Exit;
  }
  if not CanBeAssigned(SeciliPersonelIdx)
  {
    lblAtamaSonuc.Text = 'Hata: Bu personelin is yuku dolu.';
    Exit;
  }
  if ((ArrDurum.GetItem(SeciliTalepIndex) == 'Tamamlandi') or (ArrDurum.GetItem(SeciliTalepIndex) == 'Iptal'))
  {
    lblAtamaSonuc.Text = 'Hata: Bu talep atanamaz.';
    Exit;
  }

  PerId = ArrPerId.GetItem(SeciliPersonelIdx);
  PerAd = ArrPerAd.GetItem(SeciliPersonelIdx);
  TNo   = ArrTalepNo.GetItem(SeciliTalepIndex);

  if (ArrAtananPersonelId.GetItem(SeciliTalepIndex) > 0)
  {
    for (j = 0 to PersonelSayisi - 1)
    {
      if (ArrPerId.GetItem(j) == ArrAtananPersonelId.GetItem(SeciliTalepIndex))
      {
        ArrPerAktifIs.SetItem(j, ArrPerAktifIs.GetItem(j) - 1);
        break;
      }
    }
  }

  ArrAtananPersonelId.SetItem(SeciliTalepIndex, PerId);
  ArrDurum.SetItem(SeciliTalepIndex, 'Atandi');
  ArrPerAktifIs.SetItem(SeciliPersonelIdx, ArrPerAktifIs.GetItem(SeciliPersonelIdx) + 1);
  AddDurumLog(TNo, 'Atandi', PerAd + ' personeline atandi.', AktifKullaniciId);

  lblAtamaSonuc.Text = 'Basarili: ' + TNo + ' atandi.';
  lblAtamaDurum.Text = 'Durum: Atandi';
}

