// ══════════════════════════════════════════════════════════
// MODUL: SAHA PERSONELi
// ══════════════════════════════════════════════════════════

function DurumGecisiGecerliMi(MevcutDurum, YeniDurum: String): Boolean;
{
  Result = False;
  if (MevcutDurum == 'Atandi')
  {
    if (YeniDurum == 'Yolda') Result = True;
  }
  else if (MevcutDurum == 'Yolda')
  {
    if ((YeniDurum == 'Islemde') || (YeniDurum == 'Beklemede')) Result = True;
  }
  else if (MevcutDurum == 'Islemde')
  {
    if ((YeniDurum == 'Beklemede') || (YeniDurum == 'Tamamlandi')) Result = True;
  }
  else if (MevcutDurum == 'Beklemede')
  {
    if (YeniDurum == 'Islemde') Result = True;
  }
}

void RenderIsListesi;
var
  i      : Integer;
  row    : TclProPanel;
  lblNo  : TclProLabel;
  lblBas : TclProLabel;
  lblDur : TclProLabel;
  lblSLA : TclProLabel;
  btnSec : TClProButton;
  Goster : Boolean;
{
  try
    scrIsListesi.Free;
  except
  }

  scrIsListesi = SahaForm.AddNewVertScrollBox(SahaForm, 'scrIs');
  scrIsListesi.Align = alClient;
  scrIsListesi.Margins.Top = 4;

  for (i = 0 to TalepSayisi - 1)
  {
    Goster = True;
    if (ArrAtananPersonelId.GetItem(i) <> AktifKullaniciId) Goster = False;
    if (ArrDurum.GetItem(i) == 'Tamamlandi') Goster = False;
    if (ArrDurum.GetItem(i) == 'Iptal') Goster = False;
    if not Goster then Continue;

    row = SahaForm.AddNewProPanel(scrIsListesi, 'srow' + IntToStr(i));
    clComponent.SetupComponent(row, '{"Align":"Top","Height":64,"BackgroundColor":"#FFFFFF","RoundHeight":10,"RoundWidth":10,"BorderWidth":1,"BorderColor":"#E5E7EB","MarginLeft":12,"MarginRight":12,"MarginTop":8}');

    btnSec = SahaForm.AddNewProButton(row, 'bsel' + IntToStr(i), '>');
    btnSec.clTagInt = i;
    clComponent.SetupComponent(btnSec, '{"Align":"Right","Width":36,"BackgroundColor":"null","TextColor":"#6366F1","TextSize":16,"TextBold":"yes","BorderWidth":0}');
    btnSec.OnClick = 'OnIsSec';

    lblNo = SahaForm.AddNewProLabel(row, 'sno' + IntToStr(i), ArrTalepNo.GetItem(i));
    clComponent.SetupComponent(lblNo, '{"Align":"Top","Height":18,"MarginLeft":12,"MarginTop":6,"TextSize":10,"TextColor":"#6B7280","TextHorizontalAlign":"leading","BackgroundColor":"null"}');

    lblBas = SahaForm.AddNewProLabel(row, 'sbas' + IntToStr(i), ArrBaslik.GetItem(i));
    clComponent.SetupComponent(lblBas, '{"Align":"Top","Height":20,"MarginLeft":12,"TextSize":14,"TextBold":"yes","TextColor":"#111827","TextHorizontalAlign":"leading","BackgroundColor":"null"}');

    lblDur = SahaForm.AddNewProLabel(row, 'sdur' + IntToStr(i), ArrDurum.GetItem(i));
    clComponent.SetupComponent(lblDur, '{"Align":"Left","Width":90,"MarginLeft":12,"TextSize":11,"TextColor":"#374151","TextVerticalAlign":"center","BackgroundColor":"null"}');

    if (IsSLABreached(ArrHedefKapanis.GetItem(i)))
    {
      lblSLA = SahaForm.AddNewProLabel(row, 'ssla' + IntToStr(i), '! SLA');
      clComponent.SetupComponent(lblSLA, '{"Align":"Left","Width":50,"TextSize":10,"TextBold":"yes","TextColor":"#DC2626","TextVerticalAlign":"center","BackgroundColor":"null"}');
    }
    if (ArrQRDogrulandi.GetItem(i) == 1)
    {
      var lblQRok : TclProLabel;
      lblQRok = SahaForm.AddNewProLabel(row, 'sqr' + IntToStr(i), 'QR OK');
      clComponent.SetupComponent(lblQRok, '{"Align":"Left","Width":46,"TextSize":10,"TextColor":"#16A34A","TextBold":"yes","TextVerticalAlign":"center","BackgroundColor":"null"}');
    }
  }
}

void OnIsSec;
{
  SeciliIsIndex = TClProButton(SahaForm.clSender).clTagInt;
  pnlDetay.Visible = True;
  lblDetayBaslik.Text = ArrBaslik.GetItem(SeciliIsIndex);
  lblDetayDurum.Text  = 'Durum: ' + ArrDurum.GetItem(SeciliIsIndex);
  if (ArrQRDogrulandi.GetItem(SeciliIsIndex) == 1)
    lblDetayQR.Text = 'QR: Dogrulandi'
  else
    lblDetayQR.Text = 'QR: Dogrulanmadi';
  lblSahaSonuc.Text = '';
  cmbYeniDurum.ItemIndex = 0;
  edtNot.Text = '';
}

void OnDurumGuncelle;
var
  YeniDurum   : String;
  MevcutDurum : String;
  NotMt       : String;
{
  if (SeciliIsIndex < 0)
  {
    lblSahaSonuc.Text = 'Hata: Oncelikle bir is secin.';
    Exit;
  }
  YeniDurum   = Trim(cmbYeniDurum.Text);
  NotMt       = Trim(edtNot.Text);
  MevcutDurum = ArrDurum.GetItem(SeciliIsIndex);

  if (YeniDurum == '')
  {
    lblSahaSonuc.Text = 'Hata: Listeden bir durum secin.';
    Exit;
  }
  if not DurumGecisiGecerliMi(MevcutDurum, YeniDurum)
  {
    lblSahaSonuc.Text = 'Hata: ' + MevcutDurum + ' -> ' + YeniDurum + ' gecisi gecersiz.';
    Exit;
  }
  if ((YeniDurum == 'Islemde') && (ArrQRDogrulandi.GetItem(SeciliIsIndex) == 0))
  {
    lblSahaSonuc.Text = 'Hata: Islemde icin once QR dogrulama yapilmali.';
    Exit;
  }

  ArrDurum.SetItem(SeciliIsIndex, YeniDurum);
  if (NotMt <> '') ArrSonNot.SetItem(SeciliIsIndex, NotMt);
  if (YeniDurum == 'Tamamlandi')
    ArrKapanisTarihi.SetItem(SeciliIsIndex, FormatDateTime('dd.mm.yyyy hh:nn', Now));

  AddDurumLog(ArrTalepNo.GetItem(SeciliIsIndex), YeniDurum, NotMt, AktifKullaniciId);
  lblSahaSonuc.Text = 'Basarili: Durum -> ' + YeniDurum;
  lblDetayDurum.Text = 'Durum: ' + YeniDurum;
  RenderIsListesi;
  if ((YeniDurum == 'Tamamlandi') or (YeniDurum == 'Iptal'))
  {
    pnlDetay.Visible = False;
    SeciliIsIndex = -1;
  }
}

void OnSahaQRDogrula;
{
  if (SeciliIsIndex < 0)
  {
    lblSahaSonuc.Text = 'Hata: Oncelikle bir is secin.';
    Exit;
  }
  SeciliTalepIndex = SeciliIsIndex;
  SahaForm.clHide;
  BuildQRUI;
  RenderQRLog;
  QRForm.clShow;
}

void OnSahaYenile;
{
  pnlDetay.Visible = False;
  SeciliIsIndex = -1;
  RenderIsListesi;
}

void OnSahaGeri;
{
  SahaForm.clHide;
  edtKullaniciAdi.Text = '';
  edtSifre.Text = '';
  lblGirisHata.Text = '';
  GirisForm.clShow;
}

