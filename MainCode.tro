  edtSifre.Password = True;

  btnGiris = GirisForm.AddNewProButton(pnlGirisForm, 'btnGiris', 'Giris Yap');
  btnGiris.Align = alMostTop;
  btnGiris.Height = 48;
  btnGiris.Margins.Left = 24;
  btnGiris.Margins.Right = 24;
  btnGiris.Margins.Top = 20;
  clComponent.SetupComponent(btnGiris, '{"BackgroundColor":"#6366F1","TextColor":"#FFFFFF","TextSize":15,"TextBold":"yes","RoundHeight":12,"RoundWidth":12,"BorderWidth":0}');
  btnGiris.OnClick = 'OnGirisClick';

  lblGirisHata = GirisForm.AddNewProLabel(pnlGirisForm, 'lblHata', '');
  clComponent.SetupComponent(lblGirisHata, '{"Align":"Top","Height":28,"MarginTop":10,"MarginLeft":24,"TextSize":12,"TextColor":"#DC2626","TextHorizontalAlign":"leading","BackgroundColor":"null"}');
}

// ══════════════════════════════════════════════════════════
// MODUL: IS EMRi HAVUZU
// ══════════════════════════════════════════════════════════

void RenderHavuz(FiltreDurum, FiltreOncelik: String);
var
  i           : Integer;
  row         : TclProPanel;
  sep         : TclProPanel;
  lblNo       : TclProLabel;
  lblBas      : TclProLabel;
  lblOnc      : TclProLabel;
  lblDur      : TclProLabel;
  lblSLA      : TclProLabel;
  btnSec      : TClProButton;
  OncRenk     : String;
  SLABreached : Boolean;
  Goster      : Boolean;
  GosterCount : Integer;
{
  try
    scrHavuz.Free;
  except
  }

  scrHavuz = HavuzForm.AddNewVertScrollBox(HavuzForm, 'scrHavuz');
  scrHavuz.Align = alClient;
  scrHavuz.Margins.Top = 4;

  GosterCount = 0;

  for (i = 0 to TalepSayisi - 1)
  {
    Goster = True;
    if ((FiltreDurum <> '') && (ArrDurum.GetItem(i) <> FiltreDurum)) Goster = False;
    if ((FiltreOncelik <> '') && (ArrOncelik.GetItem(i) <> FiltreOncelik)) Goster = False;
    if (ArrDurum.GetItem(i) == 'Tamamlandi') Goster = False;
    if (ArrDurum.GetItem(i) == 'Iptal') Goster = False;
    if not Goster then Continue;

    GosterCount = GosterCount + 1;
    OncRenk = OncelikRenk(ArrOncelik.GetItem(i));
    SLABreached = IsSLABreached(ArrHedefKapanis.GetItem(i));

    row = HavuzForm.AddNewProPanel(scrHavuz, 'row' + IntToStr(i));
    clComponent.SetupComponent(row, '{"Align":"Top","Height":72,"BackgroundColor":"#FFFFFF","RoundHeight":10,"RoundWidth":10,"BorderWidth":1,"BorderColor":"#E5E7EB","MarginLeft":12,"MarginRight":12,"MarginTop":8}');

    sep = HavuzForm.AddNewProPanel(row, 'ind' + IntToStr(i));
    clComponent.SetupComponent(sep, '{"Align":"Left","Width":6,"BackgroundColor":"'+OncRenk+'","RoundHeight":0,"RoundWidth":0,"BorderWidth":0}');

    btnSec = HavuzForm.AddNewProButton(row, 'btnSec' + IntToStr(i), '>');
    btnSec.clTagInt = i;
    clComponent.SetupComponent(btnSec, '{"Align":"Right","Width":36,"BackgroundColor":"null","TextColor":"#6366F1","TextSize":16,"TextBold":"yes","BorderWidth":0}');
    btnSec.OnClick = 'OnTalepSec';

