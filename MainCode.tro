// ══════════════════════════════════════════════════════════
// MODUL: TALEP ACMA
// ══════════════════════════════════════════════════════════

function GenerateTalepNo: String;
{
  Result = 'TLP-' + FormatDateTime('yyyymmddhhnnss', Now) + '-' + IntToStr(NextTalepId);
}

function IsStringNumeric(S: String): Boolean;
var
  i : Integer;
{
  Result = True;
  if (Length(S) == 0) { Result = False; Exit; }
  for (i = 1 to Length(S))
  {
    if ((Copy(S, i, 1) < '0') || (Copy(S, i, 1) > '9'))
    {
      Result = False;
      Exit;
    }
  }
}

function SaveTalep: Boolean;
var
  LBaslik, LAciklama, LLokasyon, LKategori, LOncelik, TalepNo : String;
{
  Result = False;
  LBaslik   = Trim(edtBaslik.Text);
  LAciklama = Trim(edtAciklama.Text);
  LLokasyon = Trim(edtLokasyonId.Text);
  LKategori = Trim(edtKategoriId.Text);
  LOncelik  = Trim(edtOncelik.Text);

  if (LBaslik == '') { ShowMessage('Hata: Baslik bos birakilamaz.'); Exit; }
  if (LAciklama == '') { ShowMessage('Hata: Aciklama bos birakilamaz.'); Exit; }
  if (LLokasyon == '') { ShowMessage('Hata: Lokasyon bos birakilamaz.'); Exit; }
  if (LKategori == '') { ShowMessage('Hata: Kategori bos birakilamaz.'); Exit; }
  if (LOncelik == '') { ShowMessage('Hata: Oncelik secilmeli.'); Exit; }
  if (Length(LBaslik) < 5) { ShowMessage('Hata: Baslik en az 5 karakter olmali.'); Exit; }
  if not IsStringNumeric(LLokasyon) { ShowMessage('Hata: LokasyonId sayisal olmali.'); Exit; }
  if not IsStringNumeric(LKategori) { ShowMessage('Hata: KategoriId sayisal olmali.'); Exit; }

  TalepNo = GenerateTalepNo;
  ArrTalepNo.Add(TalepNo);
  ArrBaslik.Add(LBaslik);
  ArrAciklama.Add(LAciklama);
  ArrLokasyonId.Add(StrToInt(LLokasyon));
  ArrKategoriId.Add(StrToInt(LKategori));
  ArrOncelik.Add(LOncelik);
  ArrDurum.Add('Yeni');
  ArrAcanKullaniciId.Add(AktifKullaniciId);
  ArrAtananPersonelId.Add(0);
  ArrAcilisTarihi.Add(FormatDateTime('dd.mm.yyyy hh:nn', Now));
  ArrHedefKapanis.Add(CalculateSLAHedefKapanis(LOncelik));
  ArrKapanisTarihi.Add('');
  ArrSonNot.Add('');
  ArrQRDogrulandi.Add(0);
  AddDurumLog(TalepNo, 'Yeni', 'Talep olusturuldu.', AktifKullaniciId);
  TalepSayisi = TalepSayisi + 1;
  NextTalepId = NextTalepId + 1;
  Result = True;
}

void OnKaydet;
{
  if SaveTalep
  {
    ShowMessage('Basarili: Talep kaydedildi.');
    edtBaslik.Text = '';
    edtAciklama.Text = '';
    edtLokasyonId.Text = '';
    edtKategoriId.Text = '';
    edtOncelik.ItemIndex = 0;
  }
}

void OnTemizle;
{
  edtBaslik.Text = '';
  edtAciklama.Text = '';
  edtLokasyonId.Text = '';
  edtKategoriId.Text = '';
  edtOncelik.ItemIndex = 0;
}

void OnTalepGeri;
{
  TalepForm.clHide;
  if (AktifRol == 'Yonetici')
  {
    RenderHavuz('', '');
    HavuzForm.clShow;
  }
  else
  {
    edtKullaniciAdi.Text = '';
    edtSifre.Text = '';
    lblGirisHata.Text = '';
    GirisForm.clShow;
  }
}

