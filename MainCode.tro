  lblSifre = GirisForm.AddNewProLabel(pnlGirisForm, 'lblSif', 'Sifre');
  clComponent.SetupComponent(lblSifre, '{"Align":"Top","Height":24,"MarginTop":14,"MarginLeft":24,"TextSize":12,"TextColor":"#374151","TextHorizontalAlign":"leading","BackgroundColor":"null"}');

  edtSifre = GirisForm.AddNewProEdit(pnlGirisForm, 'edtSifre', '1234');
