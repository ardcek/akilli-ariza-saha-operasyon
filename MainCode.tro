  edtQRIcerik = QRForm.AddNewProEdit(pnlTarama, 'edtQR', 'QR icerigini girin...');
  clComponent.SetupComponent(edtQRIcerik, '{"Align":"Top","Height":40,"MarginLeft":16,"MarginRight":16,"MarginTop":12,"TextSize":13,"RoundHeight":10,"RoundWidth":10,"BorderWidth":0,"BackgroundColor":"#FFFFFF"}');

  btnDogrula = QRForm.AddNewProButton(pnlTarama, 'btnDog', 'Dogrula');
  clComponent.SetupComponent(btnDogrula, '{"Align":"Top","Height":40,"MarginLeft":16,"MarginRight":16,"MarginTop":8,"BackgroundColor":"#16A34A","TextColor":"#FFFFFF","TextBold":"yes","TextSize":14,"RoundHeight":10,"RoundWidth":10,"BorderWidth":0}');
  btnDogrula.OnClick = 'OnDogrula';

  lblQRSonuc = QRForm.AddNewProLabel(QRForm, 'lblSonuc', '');
  lblQRSonuc.Align = alMostTop;
