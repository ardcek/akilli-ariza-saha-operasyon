    clComponent.SetupComponent(lblNo, '{"Align":"Top","Height":18,"MarginLeft":12,"MarginTop":6,"TextSize":10,"TextColor":"#6B7280","TextHorizontalAlign":"leading","BackgroundColor":"null"}');

    lblBas = HavuzForm.AddNewProLabel(row, 'lbas' + IntToStr(i), ArrBaslik.GetItem(i));
    clComponent.SetupComponent(lblBas, '{"Align":"Top","Height":20,"MarginLeft":12,"TextSize":14,"TextBold":"yes","TextColor":"#111827","TextHorizontalAlign":"leading","BackgroundColor":"null"}');

    lblOnc = HavuzForm.AddNewProLabel(row, 'lonc' + IntToStr(i), ArrOncelik.GetItem(i));
    clComponent.SetupComponent(lblOnc, '{"Align":"Left","Width":70,"MarginLeft":12,"TextSize":11,"TextColor":"'+OncRenk+'","TextVerticalAlign":"center","BackgroundColor":"null"}');

    lblDur = HavuzForm.AddNewProLabel(row, 'ldur' + IntToStr(i), ArrDurum.GetItem(i));
    clComponent.SetupComponent(lblDur, '{"Align":"Left","Width":90,"TextSize":11,"TextColor":"#374151","TextVerticalAlign":"center","BackgroundColor":"null"}');

    if SLABreached
    {
      lblSLA = HavuzForm.AddNewProLabel(row, 'lsla' + IntToStr(i), '! SLA Asildi');
      clComponent.SetupComponent(lblSLA, '{"Align":"Left","Width":80,"TextSize":10,"TextBold":"yes","TextColor":"#DC2626","TextVerticalAlign":"center","BackgroundColor":"null"}');
    }
  }

  lblToplam.Text = 'Acik Talepler: ' + IntToStr(GosterCount);
}

