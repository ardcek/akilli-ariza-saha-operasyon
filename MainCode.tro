  HavuzForm.clSetStyle(HavuzForm.LightSB);

  AtamaForm = TclStyleForm.Create(Self);
  AtamaForm.clSetStyle(AtamaForm.LightSB);

  TalepForm = TclStyleForm.Create(Self);
  TalepForm.clSetStyle(TalepForm.LightSB);

  SahaForm = TclStyleForm.Create(Self);
  SahaForm.clSetStyle(SahaForm.LightSB);

  QRForm = TclStyleForm.Create(Self);
  QRForm.clSetStyle(QRForm.LightSB);

  DashForm = TclStyleForm.Create(Self);
