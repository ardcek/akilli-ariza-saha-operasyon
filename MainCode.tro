// ══════════════════════════════════════════════════════════
// MODUL: GIRIS
// ══════════════════════════════════════════════════════════

function AuthenticateUser(KulAdi, Sifre: String): Boolean;
var
  i : Integer;
{
  Result = False;
  for (i = 0 to ArrKulAdi.Count - 1)
  {
    if ((ArrKulAdi.GetItem(i) == Trim(KulAdi)) && (ArrKulSifre.GetItem(i) == Trim(Sifre)))
    {
      AktifKullaniciId = ArrKulId.GetItem(i);
      AktifKullaniciAd = ArrKulAdSoyad.GetItem(i);
      AktifRol = ArrKulRol.GetItem(i);
      Result = True;
      Exit;
    }
  }
}

void NavigateByRole;
{
  GirisForm.clHide;
  if (AktifRol == 'Yonetici')
  {
    lblHavuzKul.Text = AktifKullaniciAd;
    RenderHavuz('', '');
    HavuzForm.clShow;
  }
  else if (AktifRol == 'SahaPersoneli')
  {
    lblSahaKul.Text = AktifKullaniciAd;
    RenderIsListesi;
    SahaForm.clShow;
  }
  else if (AktifRol == 'TalepAcan')
  {
    lblTalepTitle.Text = 'Talep Acma — ' + AktifKullaniciAd;
    TalepForm.clShow;
  }
  else
    ShowMessage('Hata: Tanimsiz rol.');
}

void OnGirisClick;
var
  KulAdi, Sifre : String;
{
  KulAdi = Trim(edtKullaniciAdi.Text);
  Sifre  = Trim(edtSifre.Text);

  if (KulAdi == '')
  {
    lblGirisHata.Text = 'Hata: Kullanici adi bos birakilamaz.';
    Exit;
  }
  if (Sifre == '')
  {
    lblGirisHata.Text = 'Hata: Sifre bos birakilamaz.';
    Exit;
  }
  if not AuthenticateUser(KulAdi, Sifre)
  {
    lblGirisHata.Text = 'Hata: Kullanici adi veya sifre yanlis.';
    edtSifre.Text = '';
    Exit;
  }
  lblGirisHata.Text = '';
  NavigateByRole;
}

